# merge and plot

# bw --------------------------------------------------------------------------
bw_class <- merge(bw_tm, bw_jm3$pprob, by = "idno", all.x = TRUE)
surv_bw_class <- merge(surv, bw_jm3$pprob, by = "idno", all.x = TRUE)

source("R/plot_observed.R")

plot_observed_classes(
  data = bw_class,
  x = age_wk,
  y = bw,
  class = class,
  title = "Observed Body Weight Classes",
  x_label = "Age, weeks",
  y_label = "Body weight",
